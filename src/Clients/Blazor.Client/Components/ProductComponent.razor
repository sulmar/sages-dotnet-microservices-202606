@using System.ComponentModel.DataAnnotations
@using BlazorApp.Model
@using BlazorApp.Services
@inject ICartService Cart

<div class="col mb-5">
    <div class="card h-100">
        <!-- Sale badge-->
        @if (Product.IsSale)
        {
            <div class="badge bg-dark text-white position-absolute" style="top: 0.5rem; right: 0.5rem">Sale</div>
        }
        <!-- Product image-->
        <img class="card-img-top" src="https://dummyimage.com/450x300/dee2e6/6c757d.jpg" alt="..." />
        <!-- Product details-->
        <div class="card-body p-4">
            <div class="text-center">
                <!-- Product name-->
                <h5 class="fw-bolder">@Product.Name</h5>
                <!-- Product price-->
                @if(Product.IsSale)
                {
                    <span class="text-muted text-decoration-line-through">$@Product.Price</span>
                }
                $@Product.DiscountedPrice
            </div>
        </div>
        <!-- Product actions-->
        <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
            <div class="text-center">
                <a class="btn btn-outline-dark mt-auto" href="#" @onclick="AddToCart" @onclick:preventDefault="true">Add to cart</a>
                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="text-warning small mt-2">@errorMessage</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
   
    [Parameter, Required]
    public Product Product { get; set; } = null!;

    private string? errorMessage;
    
    private async Task AddToCart()
    {
        try
        {
            await Cart.AddToCartAsync(Product.Id);
            errorMessage = null;
        }
        catch (UnauthorizedApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Nie udało się dodać produktu: {ex.Message}";
        }
    }
    
}