<div class="d-flex justify-content-between align-items-center pt-3 mt-1">
    <span class="fw-bold">Razem</span>
    <span class="fw-bold">@Total.ToString("C")</span>
</div>
<button type="button"
        class="btn btn-dark w-100 mt-3"
        @onclick="OnCheckout"
        @onclick:stopPropagation="true"
        disabled="@CheckoutBusy">
    @(CheckoutBusy ? "Przetwarzanie..." : "Złóż zamówienie")
</button>

@code {
    [Parameter]
    public decimal Total { get; set; }

    [Parameter]
    public bool CheckoutBusy { get; set; }

    [Parameter]
    public EventCallback OnCheckout { get; set; }
}
